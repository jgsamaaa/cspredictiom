NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase auth and bet journal persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local preview auth only used when Supabase is not configured
NEXT_PUBLIC_DEMO_PASSWORD=research-only

# OpenAI-backed Analyst Agent. The app falls back to the local analyst model if unset.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Approved esports API providers. PandaScore is implemented for schedules.
PANDASCORE_TOKEN=
